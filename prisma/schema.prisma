generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ──────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  facebookId     String?   @unique
  username       String?   @unique
  hashedPassword String?
  role           UserRole  @default(CHAT_SUPPORT)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  shopMembers ShopMember[]
  assignedChats Chat[]       @relation("AssignedChats")
  loginEvents LoginEvent[]

  @@index([facebookId])
  @@index([email])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LoginEvent {
  id         String   @id @default(cuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  success    Boolean  @default(true)
  failReason String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

enum UserRole {
  OWNER
  MANAGER
  CHAT_SUPPORT
  WAREHOUSE
  CUSTOMER
}

// ─── Shop ──────────────────────────────────────────────────────────────────

model Shop {
  id             String   @id @default(cuid())
  name           String
  facebookPageId String?  @unique
  facebookToken  String?  @db.Text // AES-256-GCM encrypted
  defaultCurrency String  @default("THB")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members            ShopMember[]
  products           Product[]
  orders             Order[]
  customers          Customer[]
  chatConversations  Chat[]
  liveSessions       LiveSession[]
  storefrontProducts StorefrontProduct[]
  carts              Cart[]
  branding           ShopBranding?

  @@index([facebookPageId])
}

model ShopMember {
  id        String    @id @default(cuid())
  shopId    String
  userId    String
  role      UserRole  @default(CHAT_SUPPORT)
  invitedAt DateTime  @default(now())
  joinedAt  DateTime?

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([shopId])
  @@index([userId])
}

// ─── Products & Inventory ──────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  shopId      String
  stockCode   String
  saleCode    String?
  name        String
  description String?  @db.Text
  images      String[]
  categoryId  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category           ProductCategory?   @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  orderItems         OrderItem[]
  storefrontProducts StorefrontProduct[]
  cartItems          CartItem[]

  @@unique([shopId, stockCode])
  @@index([shopId])
  @@index([stockCode])
  @@index([saleCode])
}

model ProductCategory {
  id        String   @id @default(cuid())
  shopId    String
  name      String
  createdAt DateTime @default(now())

  products Product[]

  @@unique([shopId, name])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  sku         String
  attributes  Json
  price       Decimal  @db.Decimal(12, 2)
  costPrice   Decimal? @db.Decimal(12, 2)
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  lowStockAt  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  reservations StockReservation[]
  cartItems    CartItem[]

  @@unique([productId, sku])
  @@index([productId])
}

model StockReservation {
  id         String    @id @default(cuid())
  variantId  String
  orderId    String?
  quantity   Int
  expiresAt  DateTime
  releasedAt DateTime?
  createdAt  DateTime  @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([expiresAt])
}

// ─── Customers ─────────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(cuid())
  shopId        String
  facebookId    String?
  name          String
  phone         String?
  email         String?
  address       String?      @db.Text
  district      String?
  province      String?
  postalCode    String?
  labels        String[]
  shippingType  ShippingType?
  notes         String?      @db.Text
  isBanned      Boolean      @default(false)
  bannedReason  String?
  channel       SaleChannel  @default(FACEBOOK)
  lifetimeValue Decimal      @default(0) @db.Decimal(12, 2)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  shop   Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders Order[]
  chats  Chat[]
  carts  Cart[]

  @@index([shopId])
  @@index([facebookId])
  @@index([phone])
  @@index([name])
}

enum SaleChannel {
  FACEBOOK
  INSTAGRAM
  LINE
  TIKTOK
  MANUAL
  STOREFRONT
}

enum ShippingType {
  STANDARD
  EXPRESS
  PICKUP
  COD
}

// ─── Orders ────────────────────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  shopId         String
  customerId     String
  orderNumber    String
  status         OrderStatus @default(RESERVED)
  channel        SaleChannel @default(FACEBOOK)
  totalAmount    Decimal     @db.Decimal(12, 2)
  shippingFee    Decimal     @default(0) @db.Decimal(12, 2)
  notes          String?     @db.Text
  idempotencyKey String?     @unique
  reservedAt     DateTime    @default(now())
  confirmedAt    DateTime?
  packedAt       DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  shop     Shop         @relation(fields: [shopId], references: [id])
  customer Customer     @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  payment  Payment?
  shipping Shipment?
  auditLog OrderAudit[]

  @@unique([shopId, orderNumber])
  @@index([shopId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  RESERVED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  variantId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model OrderAudit {
  id          String   @id @default(cuid())
  orderId     String
  action      String
  fromStatus  String?
  toStatus    String?
  metadata    Json?
  performedBy String?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ─── Payments ──────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(cuid())
  orderId        String        @unique
  amount         Decimal       @db.Decimal(12, 2)
  status         PaymentStatus @default(PENDING)
  method         PaymentMethod @default(TRANSFER)
  slipUrl        String?
  ocrAmount      Decimal?      @db.Decimal(12, 2)
  ocrConfidence  Float?
  idempotencyKey String?       @unique
  verifiedAt     DateTime?
  refundedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([status])
}

enum PaymentStatus {
  PENDING
  VERIFIED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  TRANSFER
  QR_CODE
  COD
}

// ─── Shipping ──────────────────────────────────────────────────────────────

model Shipment {
  id             String           @id @default(cuid())
  orderId        String           @unique
  provider       ShippingProvider
  trackingNumber String?
  status         ShipmentStatus   @default(PENDING)
  labelUrl       String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([trackingNumber])
}

enum ShippingProvider {
  KEX
  JNT
  MANUAL
}

enum ShipmentStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  RETURNED
}

// ─── Chat & Messaging ──────────────────────────────────────────────────────

model Chat {
  id             String    @id @default(cuid())
  shopId         String
  customerId     String
  assignedUserId String?
  unreadCount    Int       @default(0)
  lastMessageAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  assignedUser User?         @relation("AssignedChats", fields: [assignedUserId], references: [id])
  messages     ChatMessage[]

  @@unique([shopId, customerId])
  @@index([shopId])
  @@index([assignedUserId])
}

model ChatMessage {
  id          String           @id @default(cuid())
  chatId      String
  direction   MessageDirection
  content     String           @db.Text
  mediaUrl    String?
  isRead      Boolean          @default(false)
  fbMessageId String?          @unique
  createdAt   DateTime         @default(now())

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── Live Sessions ─────────────────────────────────────────────────────────

model LiveSession {
  id           String     @id @default(cuid())
  shopId       String
  title        String?
  fbLiveId     String?    @unique
  status       LiveStatus @default(SCHEDULED)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  viewerCount  Int        @default(0)
  orderCount   Int        @default(0)
  totalRevenue Decimal    @default(0) @db.Decimal(12, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  shop Shop @relation(fields: [shopId], references: [id])

  @@index([shopId])
  @@index([status])
}

enum LiveStatus {
  SCHEDULED
  LIVE
  ENDED
}

// ─── Storefront (Customer-Facing Shop) ────────────────────────────────────

model StorefrontProduct {
  id          String    @id @default(cuid())
  shopId      String
  productId   String
  isVisible   Boolean   @default(true)
  sortOrder   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([shopId, productId])
  @@index([shopId])
  @@index([isVisible])
}

model Cart {
  id         String    @id @default(cuid())
  shopId     String
  customerId String
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shop     Shop       @relation(fields: [shopId], references: [id])
  customer Customer   @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@unique([shopId, customerId])
  @@index([shopId])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  variantId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@index([cartId])
}

// ─── Notifications ────────────────────────────────────────────────────────

model Notification {
  id        String             @id @default(cuid())
  shopId    String
  userId    String?
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean            @default(false)
  readAt    DateTime?
  createdAt DateTime           @default(now())

  @@index([shopId, isRead])
  @@index([shopId, createdAt])
  @@index([userId, isRead])
}

enum NotificationType {
  NEW_ORDER
  LOW_STOCK
  NEW_CHAT
  SHIPMENT_UPDATE
  PAYMENT_RECEIVED
  SYSTEM
}

// ─── Webhooks ─────────────────────────────────────────────────────────────

model Webhook {
  id        String         @id @default(cuid())
  shopId    String
  url       String
  secret    String
  events    String[]
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  logs WebhookLog[]

  @@index([shopId])
  @@index([shopId, isActive])
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  response    String?  @db.Text
  success     Boolean  @default(false)
  attempts    Int      @default(1)
  error       String?
  createdAt   DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([webhookId, createdAt])
}

model ShopBranding {
  id              String   @id @default(cuid())
  shopId          String   @unique
  logo            String?
  banner          String?
  primaryColor    String?
  accentColor     String?
  description     String?  @db.Text
  // Payment config
  promptpayQrUrl  String?
  promptpayNote   String?  @db.Text
  bankName        String?
  bankAccount     String?
  bankAccountName String?
  bankNote        String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

// ─── Activity Log ─────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  shopId      String
  userId      String?
  userName    String?
  action      String
  entity      String
  entityId    String?
  description String
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([shopId, entity])
  @@index([userId])
}

// ─── Exchange Rates ──────────���───────────────────────────────────────────

model ExchangeRate {
  id             String   @id @default(cuid())
  baseCurrency   String
  targetCurrency String
  rate           Decimal  @db.Decimal(12, 6)
  date           DateTime @db.Date
  source         String   @default("manual")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([baseCurrency, targetCurrency, date])
  @@index([baseCurrency, targetCurrency])
  @@index([date])
}

enum Currency {
  THB
  MYR
  SGD
}
