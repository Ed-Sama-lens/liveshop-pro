# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# user-uploaded content
/public/uploads/

# claude
.claude/

.vercel

# playwright local artifacts (auth state + screenshots + reports)
# storageState files MUST NEVER be committed — they contain auth session.
tests/e2e/.auth/
tests/e2e/screenshots/
test-results/
playwright-report/
backups/

# Local-only emergency ops scripts — never commit. See
# docs/superpowers/2026-05-15-local-ops-scripts-policy.md.
scripts/check-user-full.ts
scripts/reset-admin-password.ts
scripts/rotate-db-password.ts

# Transient one-off files used while drafting PRs / commit messages /
# smoke probes. Never commit. See
# docs/superpowers/2026-05-18-local-artifact-cleanup-policy.md.
.pr-body-*
.commit-msg.tmp
tmp-*.sh
tmp-*.ts
tmp-*.json
